{
  "name": "bookmark-cleaner",
  "description": "Open-source Python CLI tool that cleans, deduplicates, and intelligently organizes browser bookmark files",
  "techStack": {
    "methodology": "specification-driven-development",
    "language": "python",
    "minimumPython": "3.10",
    "cli": "typer",
    "testing": "pytest",
    "linting": "ruff",
    "typeChecking": "mypy"
  },
  "agents": {
    "orchestrator": "spec-kit-orchestrator",
    "planning": ["planner", "architect"],
    "implementation": ["tdd-guide", "python-expert"],
    "quality": ["code-reviewer", "security-reviewer"]
  },
  "commands": {
    "workflow": [
      "/speckit-constitution",
      "/speckit-roadmap",
      "/speckit-specify",
      "/speckit-clarify",
      "/speckit-plan",
      "/speckit-analyze",
      "/speckit-tasks",
      "/speckit-implement"
    ]
  },
  "testing": {
    "framework": "pytest",
    "coverage": {
      "minimum": 80
    },
    "types": ["unit", "integration", "e2e"]
  }
}
